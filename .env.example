# Bu faylni .env deb saqlang va o'z ma'lumotlaringizni kiriting

# BotFather dan olgan token
BOT_TOKEN=your_telegram_bot_token_here

# console.anthropic.com dan olgan API kalit
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# @userinfobot ga /start yuboring - sizning ID raqamingiz
OWNER_CHAT_ID=your_telegram_chat_id_here
