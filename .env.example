# Bu faylni .env deb nomlang va o'z ma'lumotlaringizni kiriting

# Telegram Bot Token (@BotFather dan olasiz)
BOT_TOKEN=7123456789:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Redis URL (local uchun)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Render.com uchun (deploy qilganda)
# CELERY_BROKER_URL=redis://red-xxxxxxxxxxxxxxxxxxxx:6379

# OpenWeatherMap API (bepul: openweathermap.org/api)
WEATHER_API_KEY=your_openweathermap_api_key_here
